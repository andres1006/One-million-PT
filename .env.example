# ─────────────────────────────────────────────────────────────
# OMC · Leads — Variables de entorno
# Copia este archivo a `.env.local` antes de levantar el dev server:
#   cp .env.example .env.local
# ─────────────────────────────────────────────────────────────

# MSW (Mock Service Worker) — modo offline opcional.
# Con el nuevo API layer (Next.js route handlers en `src/app/api/*`) los
# datos ya viajan por HTTP real en dev y en producción. Mantenemos MSW
# como alternativa para demos sin servidor, desactivado por defecto.
#
# `off` (default) → el cliente consume `/api/leads`, `/api/webhooks`, etc.
# `on`            → intercepta /api/* en el navegador con MSW + seed en memoria.
NEXT_PUBLIC_MOCKS=off

# ─────────────────────────────────────────────────────────────
# Resumen con IA (ruta /api/ai-summary)
#
# Si OPENAI_API_KEY está vacía, la app responde con el resumen heurístico
# (determinístico, sin costo). Si defines una key válida, se usa el modelo real.
# Nunca expongas la key al cliente: solo vive en el server runtime.
# ─────────────────────────────────────────────────────────────

# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
